Algoritmo Notas
	Definir n Como Caracter
	Escribir "Ingrese su Nota (A-F)"
	leer n 
	Segun n Hacer
		"A":
			Escribir "Excelente"
		"B":
			Escribir "Bueno"
		"C":
			Escribir "Regular"
		"D":
			Escribir "Deficiente"
		"F":
			Escribir "Reprobado"
		De Otro Modo:
			Escribir "Ingrese una Nota valida"
	Fin Segun
FinAlgoritmo
